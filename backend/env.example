# ── Database (MariaDB / MySQL) ──────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Contoh lokal: mysql://root:@localhost:3306/garuda
DATABASE_URL="mysql://root:@localhost:3306/garuda"

# ── JWT ──────────────────────────────────────────────────────────────────────
# Ganti dengan string acak yang panjang dan kuat di production
JWT_SECRET="ganti-dengan-secret-yang-kuat"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL frontend yang diizinkan akses backend
FRONTEND_URL="http://localhost:5173"
